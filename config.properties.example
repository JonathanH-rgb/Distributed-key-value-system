# ============================================================
# Distributed KV Store — configuration reference
# Copy this file to src/main/resources/config.properties
# ============================================================

# ----------------------------------------------------------
# Cluster / gossip settings  (read by ClusterConfig)
# ----------------------------------------------------------

# How many random peers each node gossips with per round
cluster.fanout.factor=3

# Seconds to wait for a gossip response before counting as a failure
cluster.gossip.timeout.secs=5

# Delay before the first gossip round fires (useful in tests to let servers boot first)
cluster.gossip.loop.delay.secs=0

# How often each node initiates a gossip round
cluster.gossip.freq.secs=1

# Consecutive failures before a node is marked DEAD (SUSPECT after the first failure)
cluster.gossip.max.attempts=3

# ----------------------------------------------------------
# Client settings  (read by ClientConfig)
# ----------------------------------------------------------

# Number of nodes a key is replicated to
client.partition.factor=3

# Minimum node responses required to return a value from a GET
client.read.consensus=2

# Minimum node acknowledgements required for a PUT or DELETE to succeed
client.write.consensus=2

# Per-operation timeouts
client.timeout.get.secs=5
client.timeout.put.secs=5
client.timeout.delete.secs=5

# How often the client refreshes its view of the cluster from seed nodes
client.refresh.rate.secs=3
client.refresh.delay.secs=0
client.refresh.threads=1
